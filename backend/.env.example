DATABASE_URL=
JWT_SECRET=
MASTER_MNEMONIC=
ETH_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NETWORK=testnet
PORT=8080
KES_PER_USD=130
EMAIL_PROVIDER=resend
EMAIL_FROM=Kashflip <noreply@kashflip.app>
EMAIL_OTP_TTL_MINUTES=10
RESEND_API_URL=https://api.resend.com/emails
RESEND_API_KEY=

# Payment top-ups: Card via Stripe, M-Pesa via Paystack, Somali wallets via Waafi.
# Set PAYMENT_SANDBOX=true only for local testing without real gateway keys.
PAYMENT_SANDBOX=false
APP_PAYMENT_RETURN_URL=https://kashflip.app/payment-return
NEXT_PUBLIC_PAYMENT_BACKEND_URL=https://backend-aroy.onrender.com
NEXT_PUBLIC_WAAFI_BACKEND_URL=https://backend-aroy.onrender.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
PAYSTACK_SECRET_KEY=
WAAFI_ENDPOINT=
WAAFI_MERCHANT_UID=
WAAFI_API_USER_ID=
WAAFI_API_KEY=

# Optional: real order execution on Binance Spot Testnet.
# Free keys: https://testnet.binance.vision (log in with GitHub).
# Leave BINANCE_ENABLE_TRADING=false to fill orders internally at live Binance prices.
BINANCE_ENV=testnet
BINANCE_ENABLE_TRADING=false
BINANCE_RECV_WINDOW=10000
BINANCE_KEY_TYPE=rsa
BINANCE_API_KEY=
BINANCE_SECRET=
BINANCE_PRIVATE_KEY_PATH=secrets/binance-rsa-private.pem
BINANCE_PRIVATE_KEY=
